<Window x:Class="S7PlcSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:S7PlcSimulator"
        mc:Ignorable="d"
        Title="S7 PLC Simulator"
        Height="760"
        Width="1280"
        MinHeight="620"
        MinWidth="980"
        Background="{DynamicResource WindowBrush}"
        Foreground="{DynamicResource TitleBrush}"
        FontFamily="Segoe UI"
        FontSize="12"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceDictionary Source="Themes/Colors.xaml" />
                    <ResourceDictionary Source="Themes/Controls.xaml" />
                </ResourceDictionary.MergedDictionaries>
                <local:ProjectNodeTypeToEmojiConverter x:Key="ProjectNodeTypeToEmojiConverter" />
                <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <Style x:Key="MonitorValueDisplayStyle" TargetType="TextBlock" BasedOn="{StaticResource GridTextDisplayStyle}">
                <Setter Property="Foreground" Value="{DynamicResource MonitorValueTextBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Background" Value="{DynamicResource MonitorValueBackgroundBrush}" />
                <Setter Property="Padding" Value="4,1" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Type}" Value="{x:Static local:PlcValueType.Array}">
                        <Setter Property="Text" Value="" />
                        <Setter Property="Background" Value="Transparent" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="StartValueDisplayStyle" TargetType="TextBlock" BasedOn="{StaticResource GridTextDisplayStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Type}" Value="{x:Static local:PlcValueType.Array}">
                        <Setter Property="Text" Value="" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <HierarchicalDataTemplate DataType="{x:Type local:ProjectTreeNode}" ItemsSource="{Binding Children}">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI Emoji"
                               FontSize="14"
                               Text="{Binding NodeType, Converter={StaticResource ProjectNodeTypeToEmojiConverter}}">
                        <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NodeType}" Value="{x:Static local:ProjectNodeType.PlcRoot}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NodeType}" Value="{x:Static local:ProjectNodeType.ProgramFolder}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NodeType}" Value="{x:Static local:ProjectNodeType.ProgramGroup}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NodeType}" Value="{x:Static local:ProjectNodeType.DataBlockFolder}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NodeType}" Value="{x:Static local:ProjectNodeType.DataBlock}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    <Image Grid.Column="0"
                           Width="14"
                           Height="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Source="/Assets/plc-controller-logo.png">
                        <Image.Style>
                                <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NodeType}" Value="{x:Static local:ProjectNodeType.PlcRoot}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <Image Grid.Column="0"
                           Width="14"
                           Height="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Source="/Assets/program-folder-logo.png">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NodeType}" Value="{x:Static local:ProjectNodeType.ProgramFolder}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NodeType}" Value="{x:Static local:ProjectNodeType.ProgramGroup}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <Image Grid.Column="0"
                           Width="14"
                           Height="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Source="/Assets/data-block-logo.png">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NodeType}" Value="{x:Static local:ProjectNodeType.DataBlockFolder}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NodeType}" Value="{x:Static local:ProjectNodeType.DataBlock}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Grid.Column="1"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Text="{Binding Name}" />
                </Grid>
            </HierarchicalDataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Background="{DynamicResource WindowBrush}">
        <Border DockPanel.Dock="Top" Height="34" Background="{DynamicResource TopBarBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1" Padding="8,0">
            <Menu VerticalAlignment="Center">
                <MenuItem Header="文件" />
                <MenuItem Header="设置">
                    <MenuItem Header="主题设置" Click="ThemeSettingsMenuItem_OnClick" />
                    <MenuItem Header="IP测试" Click="IpTestMenuItem_OnClick" />
                </MenuItem>
            </Menu>
        </Border>

        <Border DockPanel.Dock="Top" Height="56" Background="{DynamicResource HeadBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="S7 PLC Simulator" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="工业通讯调试与变量模拟" Foreground="{DynamicResource SubtleBrush}" FontSize="11" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="10,5" Margin="0,0,10,0">
                        <Grid x:Name="SimulatorRunStateLampPanel" MaxWidth="180" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="16,12,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="6" />
                <RowDefinition Height="220" MinHeight="120" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="项目" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TreeView Grid.Row="1"
                                  x:Name="ProjectTreeView"
                                  ItemsSource="{Binding ProjectNodes}"
                                  SelectedItemChanged="ProjectTreeView_OnSelectedItemChanged"
                                  PreviewMouseRightButtonDown="ProjectTreeView_OnPreviewMouseRightButtonDown"
                                  ContextMenuOpening="ProjectTreeView_OnContextMenuOpening" />
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                    <Grid>
                        <Grid Visibility="{Binding IsPlcOverviewSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Image Source="pack://application:,,,/Assets/simulator-empty-transparent.png"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Grid>
                        <ScrollViewer Visibility="{Binding IsProgramAreaSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="4">
                                <TextBlock Text="PLC模拟器介绍"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,14" />

                                <TextBlock Text="程序介绍"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6" />
                                <TextBlock TextWrapping="Wrap"
                                           Margin="0,0,0,12"
                                           Text="本模拟器用于在不连接真实 PLC 的情况下，构建并验证 S7 数据块（DB）变量读写流程，支持变量建模、地址映射、实时监视与写入测试，便于联调与教学演示。" />

                                <TextBlock Text="使用目的"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6" />
                                <TextBlock TextWrapping="Wrap"
                                           Margin="0,0,0,12"
                                           Text="用于提前发现地址配置、数据类型转换、数组定义和监控逻辑中的问题，降低现场调试成本，提升上位机与 PLC 通讯联调效率。" />

                                <TextBlock Text="主要功能"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6" />
                                <TextBlock TextWrapping="Wrap"
                                           Margin="0,0,0,12"
                                           Text="1. 项目树管理：新增/重命名/删除 PLC、程序组、数据块。&#x0a;2. 变量管理：配置名称、类型、偏移、起始值与具体地址。&#x0a;3. 数组支持：数组变量展开查看元素及实时监视。&#x0a;4. 监视与写入：支持周期刷新、右键写入与值回读。&#x0a;5. 运行日志：记录关键操作与读写结果，便于排查问题。" />

                                <TextBlock Text="使用方式与要求"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6" />
                                <TextBlock TextWrapping="Wrap"
                                           Text="1. 先在左侧项目树中创建或选择 PLC 与数据块（DB）。&#x0a;2. 进入数据块后配置变量类型与偏移，确保地址不冲突。&#x0a;3. 启动监控后查看监视值，必要时通过右键执行写入测试。&#x0a;4. 变更类型（尤其数组）后请确认起始值格式与元素数量一致。&#x0a;5. 建议按数据块分组维护变量，并通过日志确认读写是否成功。" />
                            </StackPanel>
                        </ScrollViewer>
                        <TabControl Visibility="{Binding IsDataBlockSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TabItem Header="变量">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding CurrentDataBlockName}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <Border Grid.Column="1" x:Name="MonitorTogglePanel" Background="Transparent" CornerRadius="8" Padding="4,2">
                                        <Button x:Name="MonitorToggleButton" Style="{StaticResource MonitorToggleButtonStyle}" Content="▶" Click="MonitorToggleButton_OnClick" />
                                    </Border>
                                </Grid>
                                <DataGrid Grid.Row="2"
                                          x:Name="VariablesGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserSortColumns="False"
                                          ScrollViewer.CanContentScroll="False"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          HeadersVisibility="Column"
                                          PreviewMouseRightButtonDown="VariablesGrid_OnPreviewMouseRightButtonDown"
                                          ContextMenuOpening="VariablesGrid_OnContextMenuOpening"
                                          BeginningEdit="VariablesGrid_OnBeginningEdit"
                                          CellEditEnding="VariablesGrid_OnCellEditEnding"
                                          ItemsSource="{Binding FilteredVariables}">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="DetailsVisibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Type}" Value="{x:Static local:PlcValueType.Array}" />
                                                        <Condition Binding="{Binding IsArrayExpanded}" Value="True" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="DetailsVisibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.RowDetailsTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,6"
                                                    Padding="0"
                                                    Background="{DynamicResource SurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                                    BorderThickness="1,0,1,1"
                                                    CornerRadius="0,0,6,6">
                                                <ItemsControl ItemsSource="{Binding ArrayItems}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="{Binding ElementName=VariablesGrid, Path=Columns[0].ActualWidth}" />
                                                                    <ColumnDefinition Width="{Binding ElementName=VariablesGrid, Path=Columns[1].ActualWidth}" />
                                                                    <ColumnDefinition Width="{Binding ElementName=VariablesGrid, Path=Columns[2].ActualWidth}" />
                                                                    <ColumnDefinition Width="{Binding ElementName=VariablesGrid, Path=Columns[3].ActualWidth}" />
                                                                    <ColumnDefinition Width="{Binding ElementName=VariablesGrid, Path=Columns[4].ActualWidth}" />
                                                                    <ColumnDefinition Width="{Binding ElementName=VariablesGrid, Path=Columns[5].ActualWidth}" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,0,1,1" Background="{DynamicResource PanelBrush}" Padding="6,2,6,2">
                                                                    <TextBlock Text="{Binding NameDisplay}" VerticalAlignment="Center" />
                                                                </Border>
                                                                <Border Grid.Column="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,0,1,1" Background="{DynamicResource PanelBrush}" Padding="6,2,6,2">
                                                                    <TextBlock Text="{Binding TypeDisplay}" VerticalAlignment="Center" />
                                                                </Border>
                                                                <Border Grid.Column="2" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,0,1,1" Background="{DynamicResource PanelBrush}" Padding="6,2,6,2">
                                                                    <TextBlock Text="{Binding OffsetDisplay}" VerticalAlignment="Center" />
                                                                </Border>
                                                                <Border Grid.Column="3" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,0,1,1" Background="{DynamicResource PanelBrush}" Padding="6,2,6,2">
                                                                    <TextBlock Text="{Binding StartValue}" VerticalAlignment="Center" />
                                                                </Border>
                                                                <Border Grid.Column="4" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,0,1,1" Background="{DynamicResource PanelBrush}" Padding="0">
                                                                    <TextBlock Text="{Binding Value}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource MonitorValueDisplayStyle}">
                                                                                <Setter Property="Opacity" Value="0" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding DataContext.IsMonitorEnabled, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                                        <Setter Property="Opacity" Value="1" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Border>
                                                                <Border Grid.Column="5" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,0,0,1" Background="{DynamicResource PanelBrush}" Padding="6,2,6,2">
                                                                    <TextBlock Text="{Binding AddressDisplay}" VerticalAlignment="Center" />
                                                                </Border>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </DataTemplate>
                                    </DataGrid.RowDetailsTemplate>
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="新增变量" Click="AddRowButton_OnClick" />
                                            <MenuItem Header="删除选中变量" Click="DeleteRowButton_OnClick" />
                                            <Separator x:Name="ArrayExpandSeparator" />
                                            <MenuItem x:Name="ToggleArrayExpandMenuItem" Header="展开数组" Click="ToggleArrayExpandMenuItem_OnClick" />
                                            <Separator x:Name="MonitorEditSeparator" />
                                            <MenuItem x:Name="EditMonitorValueMenuItem" Header="修改监视值" Click="EditMonitorValueMenuItem_OnClick" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn x:Name="NameColumn" Header="名称" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <ToggleButton Width="16"
                                                                      Height="16"
                                                                      Margin="0,0,4,0"
                                                                      Padding="0"
                                                                      Focusable="False"
                                                                      IsChecked="{Binding IsArrayExpanded, Mode=TwoWay}"
                                                                      Visibility="Collapsed">
                                                            <ToggleButton.Style>
                                                                <Style TargetType="ToggleButton">
                                                                    <Setter Property="Content" Value="▶" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Type}" Value="{x:Static local:PlcValueType.Array}">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter Property="Content" Value="▼" />
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ToggleButton.Style>
                                                        </ToggleButton>
                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <ToggleButton Width="16"
                                                                      Height="16"
                                                                      Margin="0,0,4,0"
                                                                      Padding="0"
                                                                      Focusable="False"
                                                                      IsChecked="{Binding IsArrayExpanded, Mode=TwoWay}"
                                                                      Visibility="Collapsed">
                                                            <ToggleButton.Style>
                                                                <Style TargetType="ToggleButton">
                                                                    <Setter Property="Content" Value="▶" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Type}" Value="{x:Static local:PlcValueType.Array}">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter Property="Content" Value="▼" />
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ToggleButton.Style>
                                                        </ToggleButton>
                                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 Padding="0"
                                                                 VerticalContentAlignment="Center" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn x:Name="TypeColumn" Header="数据类型" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding TypeEditorText}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox ItemsSource="{Binding DataContext.TypeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              DisplayMemberPath="Label"
                                                              SelectedValuePath="Value"
                                                              SelectedValue="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              IsEditable="False"
                                                              IsTextSearchEnabled="True" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn x:Name="OffsetColumn" Header="偏移量" Binding="{Binding OffsetDisplay}" IsReadOnly="True" Width="*" />
                                        <DataGridTemplateColumn x:Name="StartValueColumn" Header="起始值" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StartValueDisplay}" Style="{StaticResource StartValueDisplayStyle}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding StartValue, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn x:Name="MonitorValueColumn" Header="监视值" Binding="{Binding MonitorValueDisplay}" IsReadOnly="True" Width="*" ElementStyle="{StaticResource MonitorValueDisplayStyle}" />
                                        <DataGridTextColumn x:Name="AddressColumn" Header="具体地址" Binding="{Binding AddressDisplay}" IsReadOnly="True" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        </TabControl>
                        <StackPanel Visibility="Collapsed">
                            <TextBox x:Name="AddressTextBox" />
                            <TextBox x:Name="PortTextBox" />
                            <Button x:Name="StartButton" Click="StartButton_OnClick" />
                            <Button x:Name="StopButton" Click="StopButton_OnClick" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Row="1"
                          Height="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          Background="{DynamicResource DividerBrush}" />

            <Expander Grid.Row="2" IsExpanded="True" Header="运行日志" Background="Transparent" BorderThickness="0">
                <Border Style="{StaticResource PanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="运行日志" FontSize="13" FontWeight="SemiBold" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock x:Name="LogCountTextBlock" Style="{StaticResource LabelStyle}" Margin="0,0,10,0" Text="最近 0 条" />
                                <Button Content="清空日志" Width="88" Style="{StaticResource NeutralButtonStyle}" Click="ClearLogButton_OnClick" />
                            </StackPanel>
                        </Grid>
                        <ListBox Grid.Row="2" x:Name="LogListBox" BorderThickness="0" Background="Transparent" />
                    </Grid>
                </Border>
            </Expander>
        </Grid>
    </DockPanel>
</Window>


