<Window x:Class="S7PlcDataTester.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PLCDataTester"
        Width="1200"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#0B1220"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBg" Color="#0B1220" />
        <SolidColorBrush x:Key="CardBg" Color="#111A2E" />
        <SolidColorBrush x:Key="CardBorder" Color="#2B3550" />
        <SolidColorBrush x:Key="TextPrimary" Color="#EAF0FF" />
        <SolidColorBrush x:Key="TextMuted" Color="#9CA8C4" />
        <SolidColorBrush x:Key="AccentBlue" Color="#34D4FF" />
        <SolidColorBrush x:Key="AccentGreen" Color="#2FD38A" />
        <SolidColorBrush x:Key="AccentOrange" Color="#FFB347" />
        <SolidColorBrush x:Key="AccentGray" Color="#6D7793" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#77000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,6,10,6" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#17233C" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="#31456D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,4,0,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="White" />
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#17233C" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="#31456D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,4,0,4" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="LightComboStyle" TargetType="ComboBox" BasedOn="{StaticResource ComboStyle}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="BorderBrush" Value="#BDBDBD" />
        </Style>

        <Style x:Key="ButtonBaseStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,6,0,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.75" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="230" />
        </Grid.RowDefinitions>

        <Canvas IsHitTestVisible="False">
            <Ellipse Width="360" Height="360" Canvas.Left="-80" Canvas.Top="-120" Fill="#1E3D6A" Opacity="0.25" />
            <Ellipse Width="280" Height="280" Canvas.Right="-70" Canvas.Top="30" Fill="#2B7D7B" Opacity="0.2" />
        </Canvas>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="16,16,16,10" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="92"
                            Height="92"
                            CornerRadius="24"
                            BorderBrush="#2A4777"
                            BorderThickness="1"
                            Background="#0F1C34"
                            Margin="0,0,14,0">
                        <Grid Margin="8">
                            <Border CornerRadius="16" BorderBrush="#2E5D9E" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#142B4B" Offset="0" />
                                        <GradientStop Color="#10213A" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <Ellipse Width="48" Height="48" Fill="#1A5AA6" Opacity="0.24" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-10,-8,0,0" />
                            <Ellipse Width="44" Height="44" Fill="#1A7D74" Opacity="0.2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-8,-8" />

                            <Grid Margin="11">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" CornerRadius="8" BorderThickness="1.2" BorderBrush="#55C7FF">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2B6CB6" Offset="0" />
                                            <GradientStop Color="#215A9D" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="IT"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#F1F6FF"
                                               FontWeight="Bold"
                                               FontSize="15" />
                                </Border>

                                <Grid Grid.Row="1" Width="26" HorizontalAlignment="Center">
                                    <Rectangle Width="2"
                                               HorizontalAlignment="Center"
                                               Fill="#7EDBFF"
                                               RadiusX="1"
                                               RadiusY="1" />
                                    <Ellipse Width="6" Height="6" Fill="#7EDBFF" HorizontalAlignment="Center" VerticalAlignment="Top" />
                                    <Ellipse Width="6" Height="6" Fill="#76E5B3" HorizontalAlignment="Center" VerticalAlignment="Bottom" />
                                </Grid>

                                <Border Grid.Row="2" CornerRadius="8" BorderThickness="1.2" BorderBrush="#5DE4AE">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1E7D6D" Offset="0" />
                                            <GradientStop Color="#186857" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="OT"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#F1FFF9"
                                               FontWeight="Bold"
                                               FontSize="15" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                        <TextBlock Text="PLCDataTester" Style="{StaticResource TitleStyle}" FontSize="23" />
                        <TextBlock Text="IT/OT 工业通讯调试与数据验证平台"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="13" />
                    </StackPanel>
                </StackPanel>

                <Border x:Name="ConnectionStatusBadge"
                        Grid.Column="1"
                        Margin="10,0"
                        VerticalAlignment="Center"
                        Background="#2A1B22"
                        CornerRadius="20"
                        Padding="12,6"
                        BorderBrush="#7A2A43"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="ConnectionStatusDot"
                                 Width="8"
                                 Height="8"
                                 Fill="#E74C3C"
                                 Margin="0,0,8,0" />
                        <TextBlock x:Name="ConnectionStatusText"
                                   Text="Disconnected"
                                   Foreground="#FFB3C1"
                                   FontWeight="SemiBold"
                                   FontSize="12" />
                    </StackPanel>
                </Border>

                <Button x:Name="ConnectButton"
                        Grid.Column="2"
                        Width="124"
                        Height="38"
                        Content="Connect"
                        Background="{StaticResource AccentBlue}"
                        Style="{StaticResource ButtonBaseStyle}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="8,0,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="PLC 配置" Style="{StaticResource TitleStyle}" Margin="0,0,0,10" />

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="PLC 类型" Style="{StaticResource LabelStyle}" />
                        <ComboBox x:Name="PlcTypeComboBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource LightComboStyle}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="IP 地址" Style="{StaticResource LabelStyle}" />
                        <ComboBox x:Name="IpAddressComboBox"
                                  Grid.Row="1"
                                  Grid.Column="1"
                                  Style="{StaticResource LightComboStyle}"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  Text="192.168.1.100" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="端口" Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="PortTextBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource InputStyle}" Text="102" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="机架" Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="RackTextBox" Grid.Row="3" Grid.Column="1" Style="{StaticResource InputStyle}" Text="0" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="槽位" Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="SlotTextBox" Grid.Row="4" Grid.Column="1" Style="{StaticResource InputStyle}" Text="1" />

                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="数据测试" Style="{StaticResource TitleStyle}" Margin="0,0,0,10" />

                    <Grid Grid.Row="1" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="55" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="地址" Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="AddressTextBox" Grid.Column="1" Style="{StaticResource InputStyle}" Text="DB1.0.0" />

                        <TextBlock Grid.Column="2" Text="值" Style="{StaticResource LabelStyle}" Margin="12,6,8,6" />
                        <TextBox x:Name="ValueTextBox" Grid.Column="3" Style="{StaticResource InputStyle}" Text="0" />
                        <ComboBox x:Name="BoolValueComboBox"
                                  Grid.Column="3"
                                  Style="{StaticResource LightComboStyle}"
                                  Visibility="Collapsed" />
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,2,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="数据类型" Style="{StaticResource LabelStyle}" />
                        <ComboBox x:Name="DataTypeComboBox" Grid.Column="1" Style="{StaticResource LightComboStyle}" />
                        <TextBlock x:Name="StringLengthLabel"
                                   Grid.Column="2"
                                   Text="长度"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="12,6,8,6"
                                   Visibility="Collapsed" />
                        <TextBox x:Name="StringLengthTextBox"
                                 Grid.Column="3"
                                 Style="{StaticResource InputStyle}"
                                 Text="20"
                                 Visibility="Collapsed" />

                        <StackPanel x:Name="ByteFormatPanel"
                                    Grid.Column="4"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock Text="Byte格式"
                                       Style="{StaticResource LabelStyle}"
                                       Margin="8,6,8,6" />
                            <ComboBox x:Name="ByteFormatComboBox"
                                      Width="140"
                                      Style="{StaticResource LightComboStyle}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ReadButton"
                                Grid.Column="0"
                                Height="40"
                                Content="读取"
                                Background="{StaticResource AccentGreen}"
                                Style="{StaticResource ButtonBaseStyle}" />

                        <Button x:Name="WriteButton"
                                Grid.Column="2"
                                Height="40"
                                Content="写入"
                                Background="{StaticResource AccentOrange}"
                                Style="{StaticResource ButtonBaseStyle}" />
                    </Grid>

                    <Border Grid.Row="4" Background="#14233D" BorderBrush="#2A3E66" BorderThickness="1" CornerRadius="12" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="测试结果" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="2,0,0,6" />
                            <TextBox x:Name="ResultTextBox"
                                     Grid.Row="1"
                                     Style="{StaticResource InputStyle}"
                                     Margin="0"
                                     Background="#101A2D"
                                     BorderBrush="#1E3154"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     IsReadOnly="True" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="16,0,16,16" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="运行日志" Style="{StaticResource TitleStyle}" VerticalAlignment="Center" />

                    <Button x:Name="ClearLogButton"
                            Grid.Column="1"
                            Width="92"
                            Height="34"
                            Content="清空"
                            Background="{StaticResource AccentGray}"
                            Style="{StaticResource ButtonBaseStyle}"
                            Margin="8,0,0,0" />
                </Grid>

                <TextBox x:Name="LogTextBox"
                         Grid.Row="1"
                         Style="{StaticResource InputStyle}"
                         Margin="0"
                         Background="#0E182A"
                         BorderBrush="#20355A"
                         Foreground="#D7E6FF"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         IsReadOnly="True" />
            </Grid>
        </Border>
    </Grid>
</Window>

